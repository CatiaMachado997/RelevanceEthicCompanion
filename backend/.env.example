# PostgreSQL Configuration
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ethic-companion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Weaviate Configuration
WEAVIATE_URL=http://localhost:8080

# Groq API
GROQ_API_KEY=gsk_your_key_here

# Gemini API
GEMINI_API_KEY=your_key_here

# Tavily Search API
TAVILY_API_KEY=your_key_here

# Google Cloud
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=

# Google OAuth (Calendar + Gmail)
GOOGLE_OAUTH_CLIENT_ID=your_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/data-sources/oauth/google-calendar/callback

# Application Settings
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Security
SECRET_KEY=generate_a_random_32_byte_hex_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase Auth (required for JWT enforcement)
AUTH_ENFORCEMENT_ENABLED=False
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Slack OAuth
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_REDIRECT_URI=http://localhost:8000/api/data-sources/oauth/slack/callback

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Langfuse Observability (Sprint 2a)
LANGFUSE_PUBLIC_KEY=         # Required for observability (get from langfuse.com)
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Composio Tool Integration Platform
# Free tier: 20K tool calls/month. Get key: https://app.composio.dev/settings
COMPOSIO_API_KEY=your_composio_api_key_here
